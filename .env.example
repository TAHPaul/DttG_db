# Copy this file to .env and fill in the values for your environment.
# .env is git-ignored and must never be committed.
#
# Local development: you do NOT need a .env file at all — safe defaults are
# built into settings.py. Only create .env when you want to override something.

# Required in production — generate a new value with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to False in production
DJANGO_DEBUG=False

# Comma-separated. Must include your deployed hostname.
DJANGO_ALLOWED_HOSTS=downtotheground.rkdstudies.nl

# Must match ALLOWED_HOSTS but with scheme prefix. Required when DEBUG=False.
DJANGO_CSRF_TRUSTED_ORIGINS=https://downtotheground.rkdstudies.nl

# Absolute path where collectstatic should write files (production only).
# DJANGO_STATIC_ROOT=/path/to/staticfiles

# Absolute path to the media upload directory (production only).
# DJANGO_MEDIA_ROOT=/path/to/media
